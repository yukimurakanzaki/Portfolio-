---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Learn about my journey as a Senior Product Manager in Jakarta's fintech scene.">

  <!-- Hero -->
  <section class="py-20 border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-start md:items-center gap-10">

        <!-- Text -->
        <div class="flex-1">
          <p class="text-sky-400 font-semibold text-sm uppercase tracking-widest mb-4">About Me</p>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6 max-w-3xl">
            A PM who lives at the intersection of data, users, and business.
          </h1>
          <p class="text-slate-300 text-lg max-w-2xl leading-relaxed">
            I've spent the last 4+ years building products in Indonesia's fast-moving fintech landscape —
            from peer-to-peer lending and last-mile logistics to consumer finance.
          </p>
        </div>

        <!-- Photo -->
        <div class="flex-shrink-0">
          <img
            src="/images/profile.jpg"
            alt="Muhammad Adi Putra"
            class="w-40 h-40 md:w-52 md:h-52 rounded-2xl object-cover object-top border border-white/10 shadow-xl"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Career Story -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">

        <!-- Timeline -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-white mb-10">Career Story</h2>

          <div class="space-y-10">
            {[
              {
                period: ‘Sep 2023 – Present’,
                company: ‘PT Bussan Auto Finance (BAF)’,
                role: ‘Product Manager — BAF Mobile & BOSS Internal Platform’,
                desc: `I lead end-to-end delivery for 10+ initiatives across two product lines — BAF Mobile (consumer app) and BOSS (OPS workflows, reconciliation, submission engine) — managing a cross-functional team of 19 across BE, FE, QA, and design. I improved requirement clarity by 30% through a redesigned BRD→FSD intake workflow, delivered BAF Mobile features (Deep Link Engine, FDE Flow, Email Verification) with zero production defects across 3 release cycles, and built Agile delivery cadence from scratch across 3 teams in a previously unstructured environment.`,
              },
              {
                period: ‘Aug 2022 – Sep 2023’,
                company: ‘PT Danamas (Sinarmas Group)’,
                role: ‘Digital Product Manager — Danamas Lender Platform & Jido Gold’,
                desc: `I owned the full product roadmap for the Danamas Lender Platform (mobile + web) from discovery through launch, delivering a revamped app that improved user engagement and supported revenue growth targets. I built and launched Jido Gold from zero to first users, leading cross-functional discovery across UX, engineering, data, and compliance. I also managed payment rail integrations with BNI, Instamoney, and internal payment infrastructure.`,
              },
              {
                period: ‘Aug 2021 – Aug 2022’,
                company: ‘SiCepat Ekspres Indonesia’,
                role: ‘Associate Product Manager’,
                desc: `I delivered the first-mile outlet platform deployed across nationwide branches and launched the driver management platform (mobile + web), improving field operations efficiency across Indonesia. By restructuring backlogs and optimizing EPIC breakdowns, I improved the team’s sprint delivery speed by 18% month-over-month.`,
              },
            ].map((item, i) => (
              <div class="relative pl-8 border-l-2 border-sky-400/30">
                <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-sky-400 border-2 border-navy-950" style="border-color: #07111f;"></div>
                <p class="text-sky-400 text-xs font-semibold uppercase tracking-wider mb-1">{item.period}</p>
                <h3 class="text-white font-bold text-lg">{item.company}</h3>
                <p class="text-slate-400 text-sm font-medium mb-3">{item.role}</p>
                <p class="text-slate-300 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar: What I Stand For -->
        <div>
          <h2 class="text-2xl font-bold text-white mb-10">What I Stand For</h2>

          <div class="space-y-6">
            {[
              {
                icon: '🎯',
                title: 'Outcome over output',
                desc: 'I care about measurable user and business impact, not just shipping features on time.',
              },
              {
                icon: '🤝',
                title: 'Empathy first',
                desc: 'The best product decisions start with genuinely understanding the person on the other end.',
              },
              {
                icon: '📊',
                title: 'Data-informed, not data-obsessed',
                desc: 'I combine qualitative insights with quantitative signals to make confident decisions under uncertainty.',
              },
              {
                icon: '🚀',
                title: 'Ship, learn, iterate',
                desc: 'I believe in getting working products in front of users quickly and refining from real feedback.',
              },
            ].map(item => (
              <div class="border border-white/10 rounded-xl p-5" style="background-color: #0d1f3c;">
                <div class="text-2xl mb-3">{item.icon}</div>
                <h3 class="text-white font-semibold mb-2">{item.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Process Playbook -->
  <section class="py-20 border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-10">My Process Playbook</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            step: '1. Discovery & Gap Analysis',
            desc: 'I bridge business intent and engineering constraints by identifying requirement gaps early — reducing rework by 30% and ensuring BRD→FSD handovers are traceable and actionable.',
          },
          {
            step: '2. Agile Governance',
            desc: 'I establish Scrum ceremonies and sprint cadences from scratch, turning chaotic Excel-based tracking into high-velocity delivery with full visibility on blockers across cross-functional teams.',
          },
          {
            step: '3. Iterative Shipping',
            desc: 'I focus on outcome-based releases, using RICE prioritization to ensure every feature moves a core business KPI — not just ships on schedule.',
          },
        ].map(item => (
          <div class="p-6 rounded-2xl border border-white/10 bg-white/5">
            <h3 class="text-sky-400 font-bold mb-3">{item.step}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-20 border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-10">Skills & Tools</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { category: 'Product Strategy', items: ['OKR Setting', 'Roadmapping', 'RICE Prioritization', 'Go-to-Market', 'Competitive Analysis'] },
          { category: 'Technical & Data', items: ['SQL (Autonomous Data Extraction)', 'API Integration (BNI, Instamoney)', 'Backend Lending Architecture', 'BRD→FSD Workflow'] },
          { category: 'Execution', items: ['Agile / Scrum', 'PRD Writing', 'Stakeholder Alignment', 'Sprint Planning', 'Requirement Traceability'] },
          { category: 'Tools', items: ['Jira', 'Figma', 'Mixpanel', 'Notion', 'Claude Code', 'Kroolo'] },
        ].map(skill => (
          <div class="border border-white/10 rounded-xl p-5" style="background-color: #0d1f3c;">
            <h3 class="text-sky-400 text-sm font-semibold uppercase tracking-wider mb-4">{skill.category}</h3>
            <ul class="space-y-2">
              {skill.items.map(item => (
                <li class="text-slate-300 text-sm flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-sky-400 flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
