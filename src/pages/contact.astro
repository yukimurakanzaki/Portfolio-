---
import Layout from '../layouts/Layout.astro';

// Replace with your actual WhatsApp number (include country code, no + or spaces)
const whatsappNumber = '082386491148';
const whatsappMessage = encodeURIComponent("Hi! I found your portfolio and I'd love to connect.");
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

const email = 'muhammadadiputra789@gmail.com';
---

<Layout title="Contact" description="Get in touch with a Senior Product Manager based in Jakarta.">

  <!-- Header -->
  <section class="py-20 border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sky-400 font-semibold text-sm uppercase tracking-widest mb-4">Contact</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">
        Let's talk.
      </h1>
      <p class="text-slate-300 text-lg max-w-xl leading-relaxed">
        Whether it's a consulting engagement, a PM coaching session, or just a conversation —
        I'm happy to hear what you're working on.
      </p>
    </div>
  </section>

  <!-- Contact Options -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 max-w-2xl">

        <!-- WhatsApp -->
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col border border-white/10 rounded-2xl p-8 hover:border-green-400/40 transition-colors"
          style="background-color: #0d1f3c;"
        >
          <div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center mb-6 group-hover:bg-green-500/20 transition-colors">
            <svg class="w-6 h-6 text-green-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-white mb-2 group-hover:text-green-300 transition-colors">WhatsApp</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            The fastest way to reach me. Send a message and I'll reply within a few hours during business days.
          </p>
          <div class="mt-auto flex items-center gap-2 text-green-400 text-sm font-medium">
            <span>Message on WhatsApp</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${email}`}
          class="group flex flex-col border border-white/10 rounded-2xl p-8 hover:border-sky-400/40 transition-colors"
          style="background-color: #0d1f3c;"
        >
          <div class="w-12 h-12 rounded-xl bg-sky-400/10 flex items-center justify-center mb-6 group-hover:bg-sky-400/20 transition-colors">
            <svg class="w-6 h-6 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-white mb-2 group-hover:text-sky-300 transition-colors">Email</h2>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            For formal enquiries, consulting proposals, or longer-form conversations.
            I aim to reply within one business day.
          </p>
          <div class="mt-auto">
            <p class="text-sky-400 text-sm font-medium break-all">{email}</p>
            <div class="flex items-center gap-2 text-sky-400 text-sm font-medium mt-2">
              <span>Send an email</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="py-16 border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-10">What to include in your message</h2>
      <div class="grid sm:grid-cols-3 gap-6 max-w-3xl">
        {[
          {
            title: 'Who you are',
            desc: 'Your name, company, and role — or what stage you\'re at in your career if reaching out for coaching.',
          },
          {
            title: 'What you need',
            desc: 'A brief description of what you\'re working on or what kind of support you\'re looking for.',
          },
          {
            title: 'Timeline',
            desc: 'When you need this — helps me give you a realistic picture of availability.',
          },
        ].map(item => (
          <div>
            <h3 class="text-white font-semibold mb-2">{item.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Location note -->
  <section class="pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="border border-white/10 rounded-xl p-6 flex items-start gap-4 max-w-lg" style="background-color: #0d1f3c;">
        <svg class="w-5 h-5 text-sky-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <div>
          <p class="text-white font-semibold text-sm mb-1">Based in Jakarta, Indonesia</p>
          <p class="text-slate-400 text-sm">GMT+7. I'm available for remote engagements globally and in-person meetings across Greater Jakarta.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>
